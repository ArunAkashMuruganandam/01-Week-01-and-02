import java.util.Map;
import java.util.concurrent.ConcurrentHashMap;

class RateLimitResult {
    boolean allowed;
    long remaining;
    long retryAfterSeconds;

    public RateLimitResult(boolean allowed, long remaining, long retryAfterSeconds) {
        this.allowed = allowed;
        this.remaining = remaining;
        this.retryAfterSeconds = retryAfterSeconds;
    }
}

class Status {
    long used;
    long limit;
    long reset;

    public Status(long used, long limit, long reset) {
        this.used = used;
        this.limit = limit;
        this.reset = reset;
    }

    @Override
    public String toString() {
        return "{used: " + used + ", limit: " + limit + ", reset: " + reset + "}";
    }
}

class TokenBucket {
    private final long maxTokens;
    private final long refillIntervalMillis;
    private long currentTokens;
    private long lastRefillTimestamp;

    public TokenBucket(long maxTokens, long tokensPerHour) {
        this.maxTokens = maxTokens;
        this.refillIntervalMillis = 3600000L / tokensPerHour;
        this.currentTokens = maxTokens;
        this.lastRefillTimestamp = System.currentTimeMillis();
    }

    public synchronized RateLimitResult tryConsume() {
        refill();
        if (currentTokens > 0) {
            currentTokens--;
            return new RateLimitResult(true, currentTokens, 0);
        } else {
            long timeUntilNextToken = refillIntervalMillis - (System.currentTimeMillis() - lastRefillTimestamp);
            return new RateLimitResult(false, 0, Math.max(1, timeUntilNextToken / 1000));
        }
    }

    private void refill() {
        long now = System.currentTimeMillis();
        long elapsedTime = now - lastRefillTimestamp;
        long tokensToAdd = elapsedTime / refillIntervalMillis;

        if (tokensToAdd > 0) {
            currentTokens = Math.min(maxTokens, currentTokens + tokensToAdd);
            lastRefillTimestamp += tokensToAdd * refillIntervalMillis;
        }
    }

    public synchronized Status getStatus() {
        refill();
        long resetTimestamp = (lastRefillTimestamp + (maxTokens - currentTokens) * refillIntervalMillis) / 1000;
        return new Status(maxTokens - currentTokens, maxTokens, resetTimestamp);
    }
}

public class APIGatewayRateLimiter {

    private final Map<String, TokenBucket> clientBuckets = new ConcurrentHashMap<>();
    private final long limit;
    private final long tokensPerHour;

    public APIGatewayRateLimiter(long limit, long tokensPerHour) {
        this.limit = limit;
        this.tokensPerHour = tokensPerHour;
    }

    public String checkRateLimit(String clientId) {
        TokenBucket bucket = clientBuckets.computeIfAbsent(clientId, k -> new TokenBucket(limit, tokensPerHour));
        RateLimitResult result = bucket.tryConsume();

        if (result.allowed) {
            return "Allowed (" + result.remaining + " requests remaining)";
        } else {
            return "Denied (0 requests remaining, retry after " + result.retryAfterSeconds + "s)";
        }
    }

    public String getRateLimitStatus(String clientId) {
        TokenBucket bucket = clientBuckets.computeIfAbsent(clientId, k -> new TokenBucket(limit, tokensPerHour));
        return bucket.getStatus().toString();
    }

    public static void main(String[] args) throws InterruptedException {
        APIGatewayRateLimiter limiter = new APIGatewayRateLimiter(1000, 1000);
        String client = "abc123";

        System.out.println("checkRateLimit(clientId=\"abc123\") -> " + limiter.checkRateLimit(client));
        System.out.println("checkRateLimit(clientId=\"abc123\") -> " + limiter.checkRateLimit(client));
        
        APIGatewayRateLimiter testLimiter = new APIGatewayRateLimiter(3, 3600); 
        
        System.out.println("\n--- Testing Exhaustion ---");
        System.out.println(testLimiter.checkRateLimit("test_user")); 
        System.out.println(testLimiter.checkRateLimit("test_user")); 
        System.out.println(testLimiter.checkRateLimit("test_user")); 
        System.out.println(testLimiter.checkRateLimit("test_user")); 
        
        System.out.println("\ngetRateLimitStatus(\"test_user\") -> " + testLimiter.getRateLimitStatus("test_user"));
    }
}
