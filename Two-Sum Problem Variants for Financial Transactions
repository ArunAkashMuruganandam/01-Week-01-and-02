import java.time.Duration;
import java.time.LocalTime;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.Comparator;
import java.util.HashMap;
import java.util.HashSet;
import java.util.List;
import java.util.Map;
import java.util.Set;

class Transaction {
    int id;
    int amount;
    String merchant;
    LocalTime time;
    String accountId;

    public Transaction(int id, int amount, String merchant, String time, String accountId) {
        this.id = id;
        this.amount = amount;
        this.merchant = merchant;
        this.time = LocalTime.parse(time);
        this.accountId = accountId;
    }
}

class DuplicateAlert {
    int amount;
    String merchant;
    List<String> accounts;

    public DuplicateAlert(int amount, String merchant, List<String> accounts) {
        this.amount = amount;
        this.merchant = merchant;
        this.accounts = accounts;
    }

    @Override
    public String toString() {
        return "{amount:" + amount + ", merchant:\"" + merchant + "\", accounts:" + accounts + "}";
    }
}

public class FraudDetectionSystem {
    private final List<Transaction> transactions = new ArrayList<>();

    public void addTransaction(Transaction t) {
        transactions.add(t);
    }

    public List<String> findTwoSum(int target) {
        List<String> results = new ArrayList<>();
        Map<Integer, Transaction> seen = new HashMap<>();

        for (Transaction t : transactions) {
            int complement = target - t.amount;
            if (seen.containsKey(complement)) {
                results.add("(id:" + seen.get(complement).id + ", id:" + t.id + ")");
            }
            seen.put(t.amount, t);
        }
        return results;
    }

    public List<String> findTwoSumWithTimeWindow(int target, long windowMinutes) {
        List<String> results = new ArrayList<>();
        Map<Integer, Transaction> seen = new HashMap<>();

        for (Transaction t : transactions) {
            int complement = target - t.amount;
            if (seen.containsKey(complement)) {
                Transaction prev = seen.get(complement);
                long diffMinutes = Math.abs(Duration.between(prev.time, t.time).toMinutes());
                if (diffMinutes <= windowMinutes) {
                    results.add("(id:" + prev.id + ", id:" + t.id + ")");
                }
            }
            seen.put(t.amount, t);
        }
        return results;
    }

    public List<DuplicateAlert> detectDuplicates() {
        List<DuplicateAlert> alerts = new ArrayList<>();
        Map<String, List<Transaction>> grouped = new HashMap<>();

        for (Transaction t : transactions) {
            String key = t.amount + "_" + t.merchant;
            grouped.computeIfAbsent(key, k -> new ArrayList<>()).add(t);
        }

        for (Map.Entry<String, List<Transaction>> entry : grouped.entrySet()) {
            if (entry.getValue().size() > 1) {
                Set<String> uniqueAccounts = new HashSet<>();
                for (Transaction t : entry.getValue()) {
                    uniqueAccounts.add(t.accountId);
                }
                
                if (uniqueAccounts.size() > 1) {
                    Transaction first = entry.getValue().get(0);
                    alerts.add(new DuplicateAlert(first.amount, first.merchant, new ArrayList<>(uniqueAccounts)));
                }
            }
        }
        return alerts;
    }

    public List<List<Integer>> findKSum(int k, int target) {
        List<Transaction> sorted = new ArrayList<>(transactions);
        sorted.sort(Comparator.comparingInt(t -> t.amount));
        return kSumHelper(sorted, target, k, 0);
    }

    private List<List<Integer>> kSumHelper(List<Transaction> sorted, int target, int k, int index) {
        List<List<Integer>> res = new ArrayList<>();
        if (index >= sorted.size()) return res;

        if (k == 2) {
            int left = index;
            int right = sorted.size() - 1;
            while (left < right) {
                int sum = sorted.get(left).amount + sorted.get(right).amount;
                if (sum == target) {
                    res.add(new ArrayList<>(Arrays.asList(sorted.get(left).id, sorted.get(right).id)));
                    left++;
                    right--;
                } else if (sum < target) {
                    left++;
                } else {
                    right--;
                }
            }
        } else {
            for (int i = index; i < sorted.size() - k + 1; i++) {
                List<List<Integer>> sub = kSumHelper(sorted, target - sorted.get(i).amount, k - 1, i + 1);
                for (List<Integer> list : sub) {
                    list.add(0, sorted.get(i).id);
                    res.add(list);
                }
            }
        }
        return res;
    }

    public static void main(String[] args) {
        FraudDetectionSystem fds = new FraudDetectionSystem();
        
        fds.addTransaction(new Transaction(1, 500, "Store A", "10:00", "acc1"));
        fds.addTransaction(new Transaction(2, 300, "Store B", "10:15", "acc3"));
        fds.addTransaction(new Transaction(3, 200, "Store C", "10:30", "acc4"));
        fds.addTransaction(new Transaction(4, 500, "Store A", "10:45", "acc2"));

        System.out.println("findTwoSum(target=500) -> " + fds.findTwoSum(500));
        System.out.println("detectDuplicates() -> " + fds.detectDuplicates());
        System.out.println("findKSum(k=3, target=1000) -> " + fds.findKSum(3, 1000));
    }
}
